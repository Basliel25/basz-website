---
import BaseLayout from "../layouts/BaseLayout.astro"
import Hero from "../components/Hero.astro"

const crumbs = [{ label: "bas_", href: "/" }, { label: "About" }]

const portrait = `         ___
        /   \\
       |  o o|
       |  ▽  |
       \\_____/
      /|     |\\
     / |BAS_ | \\
    /__|_____|__\\
       |     |
       |_____|
       /     \\
      /       \\`
---

<BaseLayout title="About" description="Systems engineer, writing in public. Amsterdam." crumbs={crumbs}>
  <Hero
    section="03"
    issueLabel="Section · the short version"
    kickerStamp="COLOPHON"
    kicker="/ who is writing, and from where"
    titleHtml={`<strong>One</strong> person, <span class="u">in public</span>`}
    tag="Hi. I'm Bas — a systems-curious engineer working out loud. This page is the long-form version of my email signature."
    meta={["AMSTERDAM · UTC+1", "· OPEN FOR WORK", "· <a href='#contact'>JUMP TO CONTACT</a>"]}
  />

  <section class="editorial-head">
    <div>
      <div class="portrait-label">PORTRAIT · HAND-SET · 2025</div>
      <pre class="portrait-frame">{portrait}</pre>
      <div class="portrait-label" style="margin-top:12px;text-align:right">— fig. 1 · self</div>
    </div>
    <div class="editorial-head__divider"></div>
    <div>
      <div class="portrait-label">AT A GLANCE</div>
      <div class="sb-section__body">
        <div class="row"><span class="key">Name</span><span class="val">Bas (they/them)</span></div>
        <div class="row"><span class="key">Role</span><span class="val">Systems engineer, late-night hobbyist, <em>occasional mentor</em></span></div>
        <div class="row"><span class="key">Base</span><span class="val">Amsterdam, NL · UTC+1</span></div>
        <div class="row"><span class="key">Since</span><span class="val">First <em>hello, world</em> in 2015. Paid since 2020.</span></div>
        <div class="row"><span class="key">Stack</span><span class="val">Go · Rust · C · OCaml · Zig · nix · Linux · mutt</span></div>
        <div class="row"><span class="key">Status</span><span class="val" style="color:var(--accent)">Open to collaborations — ask me about compilers, CLIs, or making old things run.</span></div>
      </div>
    </div>
  </section>

  <section class="about-main">
    <div class="bio">
      <p>I write software the slow way, on purpose. My days start with <em>mutt</em> and a pot of coffee and end, most nights, with a <em>git commit</em> I will probably rewrite tomorrow. I work on systems — the layer of software where abstractions stop being free and start costing cycles, memory, and sometimes sleep. I like it there. I like that you can measure things.</p>

      <p>Professionally I spend my time on backends, developer tooling, and the occasional compiler. For the last three years I've been a systems engineer at a small infrastructure company — the kind of place where the code review catches a dangling <em>mmap</em> before the test suite does. Before that I studied at TU Delft, dropped out to contribute to an open-source OS, came back, and graduated by writing a thesis on memory allocator design nobody asked for.</p>

      <h2>What I work on</h2>
      <p>Four recurring interests that show up in both paid work and <a href="/projects">projects</a>. <strong>One:</strong> operating systems, especially the gap between what POSIX promises and what Linux actually does. <strong>Two:</strong> small, legible programs — the kind you can read in an afternoon and feel smarter afterwards. <strong>Three:</strong> developer tools that respect the keyboard. <strong>Four:</strong> <em>local-first software</em>, and the quiet case that it's still the best default for most things.</p>

      <h2>How I work</h2>
      <p>I write <a href="/blog">notes</a> as I go — it's the only way I've found to think at the pace of the problem. I build in public when I can. I am allergic to meetings that could have been a thread, and devoted to meetings that are properly chaired.</p>

      <blockquote>"Make it work, make it right, make it fast" — in that order, but with honesty about which one you've reached.</blockquote>

      <h2>Outside the terminal</h2>
      <p>I ride a steel bike with too many lights. I read more than I finish — currently <em>A Philosophy of Software Design</em> (again). I cook slowly, and badly.</p>
    </div>

    <aside class="sidebar">
      <div class="sb-section">
        <div class="sb-section__label">Currently</div>
        <div class="sb-section__body">
          <div class="row"><span class="key">Building</span><span class="val"><em>this site</em></span></div>
          <div class="row"><span class="key">Reading</span><span class="val"><em>A Philosophy of Software Design</em></span></div>
          <div class="row"><span class="key">Listening</span><span class="val">William Basinski — on repeat</span></div>
          <div class="row"><span class="key">Learning</span><span class="val">Zig, patiently</span></div>
        </div>
      </div>
      <div class="sb-section">
        <div class="sb-section__label">Elsewhere</div>
        <div class="sb-section__body">
          <div class="row"><span class="key">GitHub</span><span class="val"><a href="https://github.com">github.com/bas</a></span></div>
          <div class="row"><span class="key">Mastodon</span><span class="val"><a href="#">@bas@fosstodon.org</a></span></div>
          <div class="row"><span class="key">Mail</span><span class="val"><a href="mailto:hello@bas.dev">hello@bas.dev</a></span></div>
        </div>
      </div>
      <div class="sb-section">
        <div class="sb-section__label">Résumé</div>
        <div class="sb-section__body">
          <div class="row"><span class="key">Format</span><span class="val"><a href="#">PDF on request</a></span></div>
        </div>
      </div>
    </aside>
  </section>

  <section class="contact-strip" id="contact">
    <div>
      <div class="contact-strip__title">Get in touch</div>
      <p class="contact-strip__tag">I read every message. I reply to most of them. Ask me about compilers, collaborations, or weird shell scripts.</p>
    </div>
    <form class="contact-form" action="mailto:hello@bas.dev" method="get" enctype="text/plain">
      <div class="contact-form__row">
        <label class="contact-form__lbl">From</label>
        <input class="contact-form__inp" type="email" name="from" placeholder="your@email.com" />
      </div>
      <div class="contact-form__row">
        <label class="contact-form__lbl">Subject</label>
        <input class="contact-form__inp" type="text" name="subject" placeholder="Re: something interesting" />
      </div>
      <div class="contact-form__row">
        <label class="contact-form__lbl">Message</label>
        <textarea class="contact-form__inp" name="body" rows="4" placeholder="..."></textarea>
      </div>
      <button type="submit" class="contact-form__btn">SEND →</button>
    </form>
  </section>

  <section class="colo-block">
    <div class="colo-block__inner">
      <div class="colo-block__label">· COLOPHON ·</div>
      <div class="colo-block__headline">Made with intent,<br />not for scale.</div>
      <div class="colo-block__grid">
        <div class="colo-block__col">
          <h3>Stack</h3>
          <p>Astro · MDX · Sass · vanilla JS. No frameworks. No analytics. Static output on Cloudflare Pages.</p>
        </div>
        <div class="colo-block__col">
          <h3>Design</h3>
          <p>Brutalist print zine aesthetic. Anybody (display) · Playfair Display (serif) · DM Mono. No rounded corners. No gradients on UI.</p>
        </div>
        <div class="colo-block__col">
          <h3>Philosophy</h3>
          <p>Build in public. Own your words. No paywalls, no newsletters, no tracking pixels. Just pages.</p>
        </div>
      </div>
      <div class="colo-block__ticker">· bas.dev · Amsterdam · {new Date().getFullYear()} · Static · No JS required for reading · Built with intent ·</div>
    </div>
  </section>
</BaseLayout>
