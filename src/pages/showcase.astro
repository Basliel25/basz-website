<!-- Mermaid CDN — initialised after DOM ready, theme-aware -->
<script type="module" is:inline>
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs'

  const dark = document.documentElement.dataset.theme === 'dark'
  mermaid.initialize({
    startOnLoad: true,
    theme: dark ? 'dark' : 'neutral',
    themeVariables: dark
      ? { background: '#0d0c0a', primaryColor: '#252220', lineColor: '#787470', textColor: '#dedad3' }
      : { background: '#e2dfd9', primaryColor: '#c2beb8', lineColor: '#5a5652', textColor: '#141412' },
  })

  // Re-render on theme switch
  const obs = new MutationObserver(() => {
    const isDark = document.documentElement.dataset.theme === 'dark'
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'neutral',
    })
    document.querySelectorAll('.mermaid[data-processed]').forEach(el => {
      el.removeAttribute('data-processed')
      el.innerHTML = el.getAttribute('data-src') || el.textContent
    })
    mermaid.run()
  })
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] })
</script>

<!-- KaTeX — loaded as plain scripts, init via is:inline to avoid Astro template parsing -->
<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" crossorigin="anonymous"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" crossorigin="anonymous"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof renderMathInElement !== 'undefined') {
      renderMathInElement(document.body, {
        delimiters: [
          { left: '$$', right: '$$', display: true },
          { left: '$',  right: '$',  display: false }
        ]
      });
    }
  });
</script>

