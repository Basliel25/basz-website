// LaTeX equations — backslashes must be double-escaped in JS strings;
// Astro compiles raw HTML backslash sequences into JS template literals where \c = SyntaxError
const mathEq1 = '$$T_{eff} = h \\cdot T_{hit} + (1 - h) \\cdot T_{miss}$$'
const mathEq1cap = 'where $h$ is the cache hit rate, $T_{hit}$ is L1 latency (~4 cycles), $T_{miss}$ is DRAM latency (~200 cycles)'
const mathEq2 = '$$\\lambda = \\frac{N}{W} \\quad \\Leftrightarrow \\quad N = \\lambda \\cdot W$$'
const mathEq2cap = '$N$ = mean concurrency, $\\lambda$ = arrival rate (req/s), $W$ = mean latency (s)'
const mathEq3 = '$$\\text{blocks}(k) = \\left\\lfloor \\frac{M}{2^k \\cdot B} \\right\\rfloor, \\quad k \\in [0,\\, K_{\\max}]$$'
const mathEq3cap = '$M$ = heap size, $B$ = minimum block size, $K_{max} = \\log_2(M/B)$'
const mathEq4 = '$$H(X) = -\\sum_{i=1}^{n} p_i \\log_2 p_i \\quad \\text{bits/symbol}$$'
const mathEq4cap = 'Shannon entropy lower-bounds the expected code length for any prefix-free encoding'
const mathProse = `A binary search tree with $n$ nodes has expected lookup time $O(\\log n)$ in the average case,
but degenerates to $O(n)$ on sorted input — hence the need for self-balancing variants.
The AVL invariant requires $|h_L - h_R| \\leq 1$ at every node,
guaranteeing $h \\leq 1.44 \\log_2(n+2)$ for a tree of height $h$.`
const mathInlineSnippet = 'Inline math renders as $O(n \\log n)$ without display break.'

// Mermaid diagram sources — kept in frontmatter to avoid Astro parsing {braces}
